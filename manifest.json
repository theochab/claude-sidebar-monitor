{
  "manifest_version": 3,
  "name": "Claude Sidebar Monitor",
  "version": "1.0.1",
  "description": "Monitor your Claude AI usage limits at a glance with a sidebar widget. See session and weekly limits instantly.",
  "default_locale": "en",
  "permissions": ["alarms", "storage"],
  "host_permissions": ["https://claude.ai/*"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; style-src 'self'; font-src 'self'"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
